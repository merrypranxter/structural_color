# EditorConfig for Structural Color Engine
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{js,ts,jsx,tsx}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{glsl,vert,frag}]
indent_style = space
indent_size = 2
max_line_length = 100

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2

[*.{py}]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{md,markdown}]
trim_trailing_whitespace = false
max_line_length = 80

[*.{html,css,scss}]
indent_style = space
indent_size = 2
